{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Resume Designer",
  "version": "1.0.0",
  "identifier": "com.resumedesigner.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Resume Designer",
        "width": 1400,
        "height": 900,
        "minWidth": 750,
        "minHeight": 600,
        "backgroundColor": "#f8f6f3",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 19, "y": 22 },
        "decorations": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com data:; style-src-elem 'self' 'unsafe-inline' https://fonts.googleapis.com data:; img-src 'self' data: blob: asset: https://asset.localhost; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' ipc: https://ipc.localhost https://api.anthropic.com https://api.openai.com https://generativelanguage.googleapis.com; worker-src 'self' blob:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Creative resume designer and generator.",
    "longDescription": "Creative resume designer and generator.",
    "copyright": "",
    "publisher": "Ash Shah",
    "macOS": {
      "entitlements": "Entitlements.plist",
      "hardenedRuntime": true,
      "minimumSystemVersion": "11.0",
      "providerShortName": null
    },
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "languages": ["en-US"]
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/SiriusA7/Resume-Designer/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM3MTEzQjY0MzM0OUFBQjUKUldTMXFra3paRHNSTjBjMjFpMUJxMk9nbGhxcERNUXNBaTh0YmsyWUFGR29Id291b3o1WTh0NFQK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
