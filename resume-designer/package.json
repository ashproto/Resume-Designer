    "@tauri-apps/plugin-shell": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "diff": "^8.0.2",
    "dompurify": "^3.4.8",
    "html-to-image": "^1.11.13",
    "html2pdf.js": "^0.14.0",
    "mammoth": "^1.11.0",
    "marked": "^17.0.1",
    "pdfjs-dist": "^5.4.530"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
